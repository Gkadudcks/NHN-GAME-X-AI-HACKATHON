{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "One image generation JSONL record",
  "type": "object",
  "required": [
    "log_id",
    "asset_id",
    "asset_version",
    "model_name",
    "model_version",
    "prompt_version",
    "rendered_prompt",
    "reference_images",
    "seed",
    "width",
    "height",
    "settings",
    "generated_at",
    "source_output"
  ],
  "properties": {
    "log_id": { "type": "string" },
    "asset_id": { "type": "string" },
    "asset_version": { "type": "string", "pattern": "^v[0-9]{3}$" },
    "model_name": { "type": "string" },
    "model_version": { "type": "string" },
    "prompt_version": { "type": "string" },
    "rendered_prompt": { "type": ["string", "null"] },
    "reference_images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "strength"],
        "properties": {
          "path": { "type": "string" },
          "strength": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "seed": { "type": ["integer", "null"] },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "settings": { "type": "object" },
    "generated_at": { "type": ["string", "null"], "format": "date-time" },
    "source_output": { "type": ["string", "null"] }
  }
}

